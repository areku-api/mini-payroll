<%= form_with model: @employee, class: "space-y-6" do |form| %>
  <% if @employee.errors.any? %>
    <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
      <h2 class="font-semibold mb-2"><%= @employee.errors.count %> ข้อผิดพลาด</h2>
      <ul class="list-disc list-inside space-y-1">
        <% @employee.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-6 gap-4">
    <div class="md:col-span-2">
      <%= form.label :prefix, "คำนำหน้า", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= form.text_field :prefix, class: "block w-full rounded-md border-slate-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm" %>
    </div>

    <div class="md:col-span-2">
      <%= form.label :first_name, "ชื่อจริง", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= form.text_field :first_name, class: "block w-full rounded-md border-slate-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm" %>
    </div>

    <div class="md:col-span-2">
      <%= form.label :last_name, "นามสกุล", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= form.text_field :last_name, class: "block w-full rounded-md border-slate-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm" %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= form.label :salary, "เงินเดือน", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= form.number_field :salary, step: 500, class: "block w-full rounded-md border-slate-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm" %>
    </div>

    <div>
      <%= form.label :position, "ตำแหน่ง", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= form.text_field :position, class: "block w-full rounded-md border-slate-300 shadow-sm focus:border-emerald-500 focus:ring-emerald-500 text-sm" %>
    </div>
  </div>

  <div class="flex justify-end">
    <%= form.submit class: "inline-flex items-center px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm font-medium hover:bg-emerald-700 transition-colors shadow-sm" %>
  </div>
<% end %>