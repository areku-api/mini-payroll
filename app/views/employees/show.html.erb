<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-slate-800 mb-1"><%= @employee.full_name %></h1>
      <p class="text-sm text-slate-500"><%= @employee.position %></p>
    </div>
    <div class="flex items-center gap-3 text-sm">
      <%= link_to "แก้ไข", edit_employee_path(@employee), class: "text-emerald-600 hover:text-emerald-800 font-medium" %>
      <span class="text-slate-300">|</span>
      <%= link_to "กลับรายการ", employees_path, class: "text-slate-600 hover:text-emerald-600 font-medium" %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 px-6 py-6 space-y-4">
    <div class="flex items-center justify-between">
      <span class="text-sm text-slate-500">เงินเดือน</span>
      <span class="text-base font-semibold text-slate-900">
        <%= number_to_currency(@employee.salary, unit: "฿") %>
      </span>
    </div>

    <div class="pt-4 border-t border-slate-100 flex justify-end">
      <%= button_to "ลบ", @employee,
          method: :delete,
          data: { turbo_confirm: "ต้องการลบหรือไม่?" },
          class: "inline-flex items-center px-3 py-1.5 rounded-md text-sm font-medium text-red-600 hover:bg-red-50 transition-colors" %>
    </div>
  </div>
</div>